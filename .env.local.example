# Google Calendar API — Service Account credentials
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Calendar API and share the target calendar with the service account email.

GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary
SALON_TIMEZONE=America/Costa_Rica
